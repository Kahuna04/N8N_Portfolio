    {
      "parameters": {
        "jsCode": "// Extract email details from Gmail trigger\nconst items = $input.all();\n\n// Helper function to decode HTML entities\nfunction decodeHtmlEntities(text) {\n  const entities = {\n    '&lt;': '<',\n    '&gt;': '>',\n    '&amp;': '&',\n    '&quot;': '\"',\n    '&#39;': \"'\",\n    '&nbsp;': ' '\n  };\n  \n  return text.replace(/&[a-z]+;|&#\\d+;/gi, match => entities[match] || match);\n}\n\n// Helper function to extract email from \"Name <email@example.com>\" format\nfunction extractEmail(fromField) {\n  if (!fromField) return '';\n  \n  // Check if email is in angle brackets\n  const emailMatch = fromField.match(/<([^>]+)>/);\n  if (emailMatch) {\n    return emailMatch[1];\n  }\n  \n  // If no angle brackets, assume the whole string is the email\n  return fromField.trim();\n}\n\nconst results = items.map(item => {\n  const data = item.json;\n  \n  const senderRaw = data.From || '';\n  const sender = extractEmail(senderRaw);\n  const subject = data.Subject || '';\n  const to = data.To || '';\n  \n  // Extract body text - try multiple sources\n  let bodyText = '';\n  if (data.bodyText) {\n    bodyText = data.bodyText;\n  } else if (data.body) {\n    bodyText = data.body;\n  } else if (data.snippet) {\n    bodyText = data.snippet;\n  }\n  \n  // Decode HTML entities\n  if (bodyText) {\n    bodyText = decodeHtmlEntities(bodyText);\n  }\n  \n  return {\n    json: {\n      sender,\n      subject,\n      to,\n      bodyText,\n      messageId: data.id || '',\n      threadId: data.threadId || '',\n      internalDate: data.internalDate || '',\n      labels: data.labels || []\n    }\n  };\n});\n\nreturn results;"
      },
