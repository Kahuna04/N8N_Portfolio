    {
      "parameters": {
        "jsCode": "// Get the AI output time string (e.g., 'Tomorrow 10:00')\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const timeString = $('Parse Time Selection AI').item.json.output;\n  \n  // Parse the time string\n  let startTime;\n  \n  if (timeString.toLowerCase().includes('tomorrow')) {\n    // Extract the time part (e.g., '10:00')\n    const timeMatch = timeString.match(/(\\d{1,2}):(\\d{2})/);\n    \n    if (timeMatch) {\n      const hours = parseInt(timeMatch[1]);\n      const minutes = parseInt(timeMatch[2]);\n      \n      // Create tomorrow's date at the specified time\n      startTime = $now.plus({ days: 1 }).set({ hour: hours, minute: minutes, second: 0, millisecond: 0 });\n    } else {\n      // Fallback: use tomorrow at 10:00 if parsing fails\n      startTime = $now.plus({ days: 1 }).set({ hour: 10, minute: 0, second: 0, millisecond: 0 });\n    }\n  } else {\n    // Try to parse other formats or use current time + 1 day as fallback\n    startTime = $now.plus({ days: 1 }).set({ hour: 10, minute: 0, second: 0, millisecond: 0 });\n  }\n  \n  // Calculate end time (30 minutes after start)\n  const endTime = startTime.plus({ minutes: 30 });\n  \n  // Return the data with ISO formatted times\n  results.push({\n    json: {\n      ...item.json,\n      startDateTime: startTime.toISO(),\n      endDateTime: endTime.toISO(),\n      parsedTimeString: timeString\n    }\n  });\n}\n\nreturn results;"
      },
