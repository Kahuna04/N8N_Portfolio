      "id": "1ace3fb2-c100-4937-be00-0a9f8e88cd61",
      "name": "Validate Lead Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -3600,
        1120
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Lead Data:\nCompany/Name: {{ $json[\"leadName/Company\"] }}\nEmail: {{ $json.leadEmail }}\nPhone: {{ $json.leadPhone }}\nSelected Product: {{ $json.selectedProduct }}\nSelected Service: {{ $json.selectedService }}\nMessage: {{ $json.leadMessage }}\nSource: {{ $json.leadSource }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an expert lead qualification AI analyzing incoming sales leads for OpenProdkt.\n\nYour task is to:\n1. Analyze the lead data including company/name, email, phone, selected product, selected service, message, and enrichment data\n2. Evaluate lead quality based on:\n   - Product interest (MariaDB, Drawio, MySQL, TimescaleDB, WordPress, Ubuntu, Postgres, ActualBudget, RabbitMQ)\n   - Service interest (AI-as-a-service/Generative AI, Cloud adoption/Migration, Automation/Virtual assistance, OpenPlatform/Kubernetes)\n   - Message clarity and intent signals\n   - Contact information completeness\n   - Company profile and enrichment data\n3. Generate a concise lead summary (2-3 sentences) highlighting product/service interest\n4. Calculate a lead score from 0-100 where:\n   - 0-30: Low quality (unclear intent, incomplete info)\n   - 31-69: Medium quality (some interest, needs nurturing)\n   - 70-100: High quality (clear intent, specific product/service interest, complete info)\n5. Identify key qualification factors (product fit, service alignment, urgency signals)\n6. Recommend next action (immediate follow-up for specific product/service, nurture campaign, or disqualify)\n\nReturn your analysis in the structured JSON format."
        }
      },
      "id": "64fd1d27-da0e-4985-9aa3-1287a2f0e9ce",
      "name": "AI Summarize & Score Lead",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        -3376,
        1120
      ]
    },
    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n\t\"type\": \"object\",\n\t\"properties\": {\n\t\t\"leadScore\": {\n\t\t\t\"type\": \"number\",\n\t\t\t\"description\": \"Lead quality score from 0-100\"\n\t\t},\n\t\t\"leadQuality\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Lead quality tier: low, medium, or high\"\n\t\t},\n\t\t\"leadSummary\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Brief 2-3 sentence summary of the lead\"\n\t\t},\n\t\t\"qualificationFactors\": {\n\t\t\t\"type\": \"array\",\n\t\t\t\"items\": {\n\t\t\t\t\"type\": \"string\"\n\t\t\t},\n\t\t\t\"description\": \"Key factors influencing qualification\"\n\t\t},\n\t\t\"recommendedAction\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Recommended next action\"\n\t\t}\n\t}\n}"
      },
