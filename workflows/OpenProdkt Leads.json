    {
      "parameters": {
        "sendTo": "={{ $('Workflow Configuration').first().json.emailSequenceRecipient }}",
        "subject": "=New Lead: {{ $('Validate Lead Data').first().json.leadName }} (Score: {{ $json.leadScore }})",
        "message": "=<h2>New Lead Received - OpenProdkt</h2>\n<p><strong>Company/Name:</strong> {{ $('Validate Lead Data').first().json.leadName }}</p>\n<p><strong>Email:</strong> {{ $('Validate Lead Data').first().json.leadEmail }}</p>\n<p><strong>Phone:</strong> {{ $('Validate Lead Data').first().json.leadPhone }}</p>\n<p><strong>Selected Product:</strong> {{ $('Validate Lead Data').first().json.selectedProduct }}</p>\n<p><strong>Selected Service:</strong> {{ $('Validate Lead Data').first().json.selectedService }}</p>\n<p><strong>Message:</strong> {{ $('Validate Lead Data').first().json.leadMessage }}</p>\n<p><strong>Source:</strong> {{ $('Validate Lead Data').first().json.leadSource }}</p>\n<hr>\n<h3>AI Analysis</h3>\n<p><strong>Lead Score:</strong> {{ $json.leadScore }}/100</p>\n<p><strong>Quality:</strong> {{ $json.leadQuality }}</p>\n<p><strong>Summary:</strong> {{ $json.leadSummary }}</p>\n<p><strong>Qualification Factors:</strong></p>\n<ul>\n{{ $json.qualificationFactors.map(factor => `<li>${factor}</li>`).join(\"\") }}\n</ul>\n<p><strong>Recommended Action:</strong> {{ $json.recommendedAction }}</p>\n<hr>\n<p><em>Lead stored in database and ready for follow-up.</em></p>",
        "options": {}
      },
